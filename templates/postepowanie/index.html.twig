{% extends 'base.html.twig' %}

{% block title %}Postępowania{% endblock %}

{% block body %}
    <div class="container">

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h1 class="mb-0">Postępowania</h1>

            <a class="btn btn-success" href="{{ path('app_postepowanie_new') }}">
                + Nowe postępowanie
            </a>
        </div>

        {# Filtry statusu #}
        <div class="btn-group mb-3" role="group">
            <a class="btn btn-outline-primary {% if filter == 'active' %}active{% endif %}"
               href="{{ path('app_postepowanie_index', {'filter':'active'}) }}">Aktywne</a>
            <a class="btn btn-outline-primary {% if filter == 'closed' %}active{% endif %}"
               href="{{ path('app_postepowanie_index', {'filter':'closed'}) }}">Zakończone</a>
            <a class="btn btn-outline-primary {% if filter == 'all' %}active{% endif %}"
               href="{{ path('app_postepowanie_index', {'filter':'all'}) }}">Wszystkie</a>
        </div>

        {# Filtry #}
        <form method="get" class="card p-3 mb-3">
            <input type="hidden" name="filter" value="{{ filter }}">

            <div class="row g-2 align-items-end">

                <div class="col-md-3">
                    <label class="form-label small">Szukaj</label>
                    <input type="text" name="search" value="{{ search ?? '' }}"
                           class="form-control" placeholder="Numer lub opis...">
                </div>

                <div class="col-md-3">
                    <label class="form-label small">Prowadzący</label>
                    <select name="prowadzacy" class="form-select">
                        <option value="">Wszyscy</option>
                        {% for p in pracownicy %}
                            <option value="{{ p.id }}"
                                    {% if prowadzacySelected == p.id %}selected{% endif %}>
                                {{ p }}
                            </option>
                        {% endfor %}
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label small">Od</label>
                    <input type="date" name="from" value="{{ from ?? '' }}" class="form-control">
                </div>

                <div class="col-md-2">
                    <label class="form-label small">Do</label>
                    <input type="date" name="to" value="{{ to ?? '' }}" class="form-control">
                </div>

                <div class="col-md-2 d-flex gap-2">
                    <button class="btn btn-primary w-100">Filtruj</button>
                    <a href="{{ path('app_postepowanie_index', {'filter': filter}) }}"
                       class="btn btn-outline-secondary w-100">
                        Reset
                    </a>
                </div>

            </div>
        </form>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-success">{{ message }}</div>
            {% endfor %}
        {% endfor %}

        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <thead class="table-light">
                <tr>
                    <th>Lp</th>

                    <th>
                        {% set isSorted = sort == 'numer' %}
                        <a class="sort-link"
                           href="{{ path('app_postepowanie_index', app.request.query.all | merge({
                               sort: 'numer',
                               direction: isSorted and direction == 'asc' ? 'desc' : 'asc'
                           })) }}">
                            Numer
                            {% if isSorted %}
                                {% if direction == 'asc' %}▲{% else %}▼{% endif %}
                            {% endif %}
                        </a>
                    </th>

                    <th>Prowadzący</th>
                    <th>Rodzaj</th>

                    <th>
                        {% set isSorted = sort == 'dataWszczecia' %}
                        <a class="sort-link"
                           href="{{ path('app_postepowanie_index', app.request.query.all | merge({
                               sort: 'dataWszczecia',
                               direction: isSorted and direction == 'asc' ? 'desc' : 'asc'
                           })) }}">
                            Data wszczęcia
                            {% if isSorted %}
                                {% if direction == 'asc' %}▲{% else %}▼{% endif %}
                            {% endif %}
                        </a>
                    </th>

                    <th>Data zakończenia</th>
                    <th>Status</th>
                    <th class="text-end">Akcje</th>
                </tr>
                </thead>

                <tbody>
                {% for postepowanie in pagination %}
                    {% set status = postepowanie.status %}
                    {% set canApprove = is_granted('ROLE_ADMIN') or is_granted('ROLE_SUPERVISOR') %}

                    <tr>
                        <td>
                            {{ (pagination.currentPageNumber - 1) * pagination.itemNumberPerPage + loop.index }}
                        </td>

                        <td class="fw-semibold">{{ postepowanie.numer }}</td>
                        <td>{{ postepowanie.prowadzacy ?? '-' }}</td>
                        <td>{{ postepowanie.rodzaj }}</td>
                        <td>{{ postepowanie.dataWszczecia|date('Y-m-d') }}</td>
                        <td>{{ postepowanie.dataZakonczenia ? postepowanie.dataZakonczenia|date('Y-m-d') : '-' }}</td>

                        <td>
                            <span class="badge
                                {% if status == constant('App\\Entity\\Postepowanie::STATUS_APPROVED') %}bg-success
                                {% elseif status == constant('App\\Entity\\Postepowanie::STATUS_WAITING_APPROVAL') %}bg-secondary
                                {% elseif status == constant('App\\Entity\\Postepowanie::STATUS_WAITING_DELETE_APPROVAL') %}bg-warning text-dark
                                {% else %}bg-light text-dark
                                {% endif %}
                            ">
                                {{ status|status_pl }}
                            </span>
                        </td>

                        <td class="text-end">
                            <div class="btn-group btn-group-sm">

                                <a class="btn btn-outline-primary"
                                   href="{{ path('app_postepowanie_show', {'id': postepowanie.id}) }}">
                                    Podgląd
                                </a>

                                {% if status == constant('App\\Entity\\Postepowanie::STATUS_WAITING_APPROVAL') and canApprove %}
                                    <form method="post"
                                          action="{{ path('app_postepowanie_approve', {'id': postepowanie.id}) }}"
                                          onsubmit="return confirm('Na pewno zatwierdzić?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('approve' ~ postepowanie.id) }}">
                                        <button class="btn btn-success">Zatwierdź</button>
                                    </form>
                                {% endif %}

                                {% if status != constant('App\\Entity\\Postepowanie::STATUS_WAITING_DELETE_APPROVAL') %}
                                    <a class="btn btn-outline-secondary"
                                       href="{{ path('app_postepowanie_edit', {'id': postepowanie.id }) }}">
                                        Edytuj
                                    </a>
                                {% endif %}

                                <form method="post"
                                      action="{{ path('app_postepowanie_delete', {'id': postepowanie.id}) }}"
                                      onsubmit="return confirm('Czy na pewno?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ postepowanie.id) }}">
                                    <button class="btn btn-outline-danger"
                                            {% if status == constant('App\\Entity\\Postepowanie::STATUS_WAITING_DELETE_APPROVAL') and not is_granted('ROLE_SUPERVISOR') %}disabled{% endif %}>
                                        {% if is_granted('ROLE_SUPERVISOR') %}
                                            Usuń
                                        {% else %}
                                            {% if status == constant('App\\Entity\\Postepowanie::STATUS_WAITING_DELETE_APPROVAL') %}
                                                Wysłano
                                            {% else %}
                                                Zgłoś usunięcie
                                            {% endif %}
                                        {% endif %}
                                    </button>
                                </form>

                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="8" class="text-center text-muted">
                            Brak postępowań
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>

        <div class="d-flex justify-content-between align-items-center mt-4">
            <div class="text-muted small">
                Strona {{ pagination.currentPageNumber }}
            </div>

            <div>
                {{ knp_pagination_render(pagination, 'pagination/pagination.html.twig') }}
            </div>
        </div>

    </div>
{% endblock %}
