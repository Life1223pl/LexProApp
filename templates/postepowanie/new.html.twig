{% extends 'base.html.twig' %}

{% block title %}Nowe postępowanie{% endblock %}

{% block body %}
    <div class="container mt-4">

        <div class="d-flex justify-content-between align-items-start mb-3">
            <div>
                <h1 class="mb-1">Nowe postępowanie</h1>
                <div class="text-muted">Utworzenie nowego postępowania</div>
            </div>

            <a href="{{ path('app_postepowanie_index') }}" class="btn btn-outline-secondary">
                ← Wróć do listy
            </a>
        </div>

        <div class="card shadow-sm">
            <div class="card-body">

                {{ form_start(form) }}

                <div class="row g-3">
                    {# Numer #}
                    {% if form.numer is defined %}
                        <div class="col-md-6">
                            {{ form_row(form.numer) }}
                        </div>
                    {% endif %}

                    {# Rodzaj (select) #}
                    {% if form.rodzaj is defined %}
                        <div class="col-md-6">
                            {{ form_row(form.rodzaj) }}
                        </div>
                    {% endif %}

                    {# Data wszczęcia #}
                    {% if form.dataWszczecia is defined %}
                        <div class="col-md-6">
                            {{ form_row(form.dataWszczecia) }}
                        </div>
                    {% endif %}

                    {# Główny artykuł #}
                    {% if form.glownyArtykulSprawy is defined %}
                        <div class="col-md-6">
                            {{ form_row(form.glownyArtykulSprawy) }}
                        </div>
                    {% endif %}

                    {# Opis / inne pola jeśli istnieją #}
                    {% if form.opis is defined %}
                        <div class="col-12">
                            {{ form_row(form.opis) }}
                        </div>
                    {% endif %}
                </div>

                {# Jeśli w formie są jeszcze jakieś pola, pokaż je automatycznie #}
                <div class="mt-3">
                    {{ form_rest(form) }}
                </div>

                <hr class="my-4">

                <div class="d-flex justify-content-between">
                    <a href="{{ path('app_postepowanie_index') }}" class="btn btn-outline-secondary">
                        Anuluj
                    </a>

                    <button class="btn btn-primary">
                        Zapisz postępowanie
                    </button>
                </div>

                {{ form_end(form) }}

            </div>
        </div>

    </div>
{% endblock %}
