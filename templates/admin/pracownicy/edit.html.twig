{% extends 'base.html.twig' %}

{% block title %}Edycja użytkownika{% endblock %}

{% block body %}
    <div class="container mt-4" style="max-width: 700px;">

        <div class="card shadow-sm">
            <div class="card-body">

                <h2 class="mb-4">Edycja użytkownika</h2>

                {{ form_start(form) }}

                <div class="mb-3">
                    {{ form_label(form.email, 'Email') }}
                    {{ form_widget(form.email, {'attr': {'class': 'form-control'}}) }}
                </div>

                <div class="mb-3">
                    {{ form_label(form.imie, 'Imię') }}
                    {{ form_widget(form.imie, {'attr': {'class': 'form-control'}}) }}
                </div>

                <div class="mb-3">
                    {{ form_label(form.nazwisko, 'Nazwisko') }}
                    {{ form_widget(form.nazwisko, {'attr': {'class': 'form-control'}}) }}
                </div>

                <div class="mb-3">
                    {{ form_label(form.stopien, 'Stopień') }}
                    {{ form_widget(form.stopien, {'attr': {'class': 'form-control'}}) }}
                </div>

                <div class="mb-3">
                    {{ form_label(form.funkcja, 'Funkcja') }}
                    {{ form_widget(form.funkcja, {'attr': {'class': 'form-control'}}) }}
                </div>

                <div class="mb-3">
                    {{ form_label(form.miejsceZatrudnienia, 'Miejsce zatrudnienia') }}
                    {{ form_widget(form.miejsceZatrudnienia, {'attr': {'class': 'form-control'}}) }}
                </div>

                <div class="mb-3">
                    {{ form_label(form.przelozony, 'Przełożony') }}
                    {{ form_widget(form.przelozony, {'attr': {'class': 'form-select'}}) }}
                </div>

                <div class="mb-3">
                    {{ form_row(form.plainPassword.first) }}
                </div>

                <div class="mb-3">
                    {{ form_row(form.plainPassword.second) }}
                </div>

                <div class="form-text mb-3">
                    Zostaw puste jeśli nie chcesz zmieniać hasła
                </div>

                {#  ROLE #}
                <div class="mb-4">
                    <label class="form-label">Role użytkownika</label>

                    {% set userRoles = pracownik.roles %}

                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="roles[]" value="ROLE_USER"
                               {% if 'ROLE_USER' in userRoles %}checked{% endif %}>
                        <label class="form-check-label">User</label>
                    </div>

                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="roles[]" value="ROLE_SUPERVISOR"
                               {% if 'ROLE_SUPERVISOR' in userRoles %}checked{% endif %}>
                        <label class="form-check-label">Przełożony</label>
                    </div>

                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="roles[]" value="ROLE_ADMIN"
                               {% if 'ROLE_ADMIN' in userRoles %}checked{% endif %}>
                        <label class="form-check-label">Admin</label>
                    </div>
                </div>

                <div class="form-check mb-4">
                    {{ form_widget(form.isActive, {'attr': {'class': 'form-check-input'}}) }}
                    {{ form_label(form.isActive, 'Konto aktywne', {'label_attr': {'class': 'form-check-label'}}) }}
                </div>

                <div class="d-flex justify-content-between">
                    <a href="{{ path('admin_pracownicy_index') }}" class="btn btn-outline-secondary">
                        ← Powrót
                    </a>

                    <button class="btn btn-success">
                        ✔ Zapisz zmiany
                    </button>
                </div>

                {{ form_end(form) }}

            </div>
        </div>

    </div>
{% endblock %}
