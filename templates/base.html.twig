<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}LexPro{% endblock %}</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset('css/a11y.css') }}">
</head>
<body>

<nav class="navbar navbar-expand-lg navbar-light bg-light border-bottom mb-4">
    <div class="container-fluid">
        <a class="navbar-brand fw-bold" href="{{ path('app_home') }}">LexPro</a>


        <div class="d-flex align-items-center gap-3">
            {% if app.user %}
                <span class="text-muted small">{{ app.user.email }}</span>
                <a class="btn btn-outline-danger btn-sm" href="{{ path('app_logout') }}">Wyloguj</a>
            {% endif %}
            <button type="button" class="btn btn-outline-secondary btn-sm" id="a11yToggle" title="Zwiększony kontrast i czytelność dla osób z daltonizmem">
                Tryb daltonisty
            </button>

        </div>
    </div>
</nav>

<main>
    {% block body %}{% endblock %}
</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
    (function () {
        const key = 'a11y_colorblind';
        const root = document.documentElement;

        function apply(val) {
            root.classList.toggle('a11y-colorblind', val === '1');
        }

        const saved = localStorage.getItem(key) || '0';
        apply(saved);

        const btn = document.getElementById('a11yToggle');
        if (btn) {
            btn.addEventListener('click', () => {
                const next = root.classList.contains('a11y-colorblind') ? '0' : '1';
                localStorage.setItem(key, next);
                apply(next);
            });
        }
    })();
</script>
<style>
    .sort-link {
        color: inherit;
        text-decoration: none;
        font-weight: 500;
    }

    .sort-link:hover {
        text-decoration: underline;
        cursor: pointer;
        opacity: 0.8;
    }
</style>
</body>
</html>
